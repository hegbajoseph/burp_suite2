</span><span>]
</span><span>
</span><span>WSGI_APPLICATION = 'tuto.wsgi.application'
</span><span>
</span><span>
</span><span># Database
</span><span># https://docs.djangoproject.com/en/6.0/ref/settings/#databases
</span><span>
</span><span>DATABASES = {

rgb(179, 74, 0);">cd</span><span> C:</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>Users</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>NICK-TECH</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>Desktop</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>burp_suite
</span></span><span class="token token" style="color: rgb(0, 128, 0);"><span>env</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>Scripts</span><span class="token token" style="color: rgb(43, 48, 59);">\</span><span>activate
</span></span><span class="token token" style="color: rgb(0, 128, 0);"><span>python -c </span><span class="token token" style="color: rgb(0, 128, 0);">"
</span></span><span class="token token" style="color: rgb(0, 128, 0);">import json, os
</span><span class="token token" style="color: rgb(0, 128, 0);">pending_file = r'mon_projet\pending_requests.json'
</span><span class="token token" style="color: rgb(0, 128, 0);"><span class="token token" style="color: rgb(0, 128, 0);">forward_file = r'mon_projet</span><span class="token token" style="color: rgb(0, 128, 128);">\f</span><span class="token token" style="color: rgb(0, 128, 0);">orward_signal.txt'
</span></span><span class="token token" style="color: rgb(0, 128, 0);">with open(pending_file, 'r') as f:
</span><span class="token token" style="color: rgb(0, 128, 0);">    pending = json.load(f)
</span><span class="token token" style="color: rgb(0, 128, 0);">print('Pending:', pending)
</span><span class="token token" style="color: rgb(0, 128, 0);">proxy_key = list(pending.keys())[0]
</span><span class="token token" style="color: rgb(0, 128, 0);">print('Proxy key:', proxy_key)
</span><span class="token token" style="color: rgb(0, 128, 0);">with open(forward_file, 'w') as f:
</span><span class="token token" style="color: rgb(0, 128, 0);">    f.write(proxy_key)
</span><span class="token token" style="color: rgb(0, 128, 0);">print('Signal ecrit!')
</span><span class="token token" style="color: rgb(0, 128, 0);">"</span></code></pre></div></div>
